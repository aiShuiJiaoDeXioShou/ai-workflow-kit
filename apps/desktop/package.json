    "@flowgram.ai/node": "1.0.12",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "lucide-react": "^1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "2.11.3",
    "@types/node": "22.19.3",
